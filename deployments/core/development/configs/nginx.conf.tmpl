user nginx;
worker_processes auto;

events {
    worker_connections 1024;
}

http {
    include       mime.types;
    default_type  application/octet-stream;

    include /etc/nginx/conf.d/logs.conf;

    sendfile on;
    tcp_nopush on;
    tcp_nodelay on;

    keepalive_timeout 65;

    gzip on;
    gzip_types text/plain text/css application/json application/javascript application/xml;

    # Docker real client IP handling
    real_ip_header X-Forwarded-For;
    set_real_ip_from 172.16.0.0/12;

    # Nginx healthcheck for Keepalived
    server {
        listen 443 ssl;
        server_name _;

        ssl_certificate     /etc/nginx/ssl/*.${DOMAIN}_ecc/fullchain.cer;
        ssl_certificate_key /etc/nginx/ssl/*.${DOMAIN}_ecc/*.${DOMAIN}.key;

        access_log syslog:server=rsyslog.${DOMAIN},tag=default,severity=info json;
        error_log  syslog:server=rsyslog.${DOMAIN},tag=default,severity=info;

        location = /health {
            access_log off;
            return 200 "OK\n";
            add_header Content-Type text/plain;
        }

        location / {
            return 404;
        }
    }

    # Load all proxy host configs
    include /etc/nginx/conf.d/proxy_host/*.conf;
}
